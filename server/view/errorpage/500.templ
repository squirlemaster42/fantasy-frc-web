package errorpage

import (
	"server/types"
	"server/view"
)

templ ServerError500(page string, fromProtected bool, username string, data types.PageData) {
	@view.Index(page, fromProtected, username, data) {
		<section class="flex flex-col items-center justify-center min-h-[80vh] gap-6 px-4">
			<div class="items-center justify-center flex flex-col gap-4">
				<h1 class="text-9xl font-extrabold text-base-content/20 tracking-widest">500</h1>
				<h2 class="bg-error text-error-content px-3 py-1 text-sm rounded-lg rotate-12 absolute shadow-lg">Server error</h2>
			</div>
			<p class="text-sm text-center md:text-base text-base-content/70 max-w-md">
				Something went wrong on our end. Please try again later or contact support if the problem persists.
			</p>
			if fromProtected {
				<a href="/u/home" class="btn btn-primary btn-outline mt-2">Go Home</a>
			} else {
				<a href="/" class="btn btn-primary btn-outline mt-2">Go Home</a>
			}
		</section>
	}
}
