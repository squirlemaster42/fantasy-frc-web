# Database Configuration
DB_IP=localhost
DB_NAME=fantasy_frc
DB_USERNAME=postgres
DB_PASSWORD=your_password_here

# Server Configuration
SERVER_PORT=3000

# The Blue Alliance API Token
TBA_TOKEN=your_tba_token_here

# The Blue Alliance Webhook Secret
TBA_WEBHOOK_SECRET=your_webhook_secret_here

# Metrics Collection Secret
METRIC_SECRET=your_metric_secret_here

# OpenTelemetry Configuration
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_RESOURCE_ATTRIBUTES=service.name=fantasy-frc-web

# Secure http cookies. False for dev, true for prod. Defaults to true
SECURE_HTTP_COOKIE=false

# CSRF Protection Secret (required). Should be a long random string
CSRF_SECRET=your_csrf_secret_here_change_me

# Password Policy - Minimum password length (default: 12)
MIN_PASSWORD_LENGTH=12

# Rate Limiting - Max POST requests per minute per user (default: 100)
RATE_LIMIT_POSTS_PER_MINUTE=100

# Rate Limiting - Enable/disable rate limiting globally (default: true)
RATE_LIMIT_ENABLED=true

# Redis Configuration for distributed rate limiting
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_RATE_LIMIT_DB=1
REDIS_AVATAR_DB=2
