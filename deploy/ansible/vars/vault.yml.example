---
# Ansible Vault Variables
# Copy this file to vars/vault.yml and encrypt with: ansible-vault encrypt vars/vault.yml
# Then fill in your actual values

vault_db_password: "your_database_password_here"
vault_tba_token: "your_tba_api_token_here"
vault_tba_webhook_secret: "your_webhook_secret_here"
vault_sentry_dsn: ""
vault_session_secret: "your_random_session_secret_here"
