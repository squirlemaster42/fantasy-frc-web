apiVersion: apps/v1
kind: Deployment
metadata:
  name: fantasy-frc-web
  namespace: {{ fantasy_frc_namespace }}
  labels:
    app: fantasy-frc-web
spec:
  replicas: {{ fantasy_frc_replicas }}
  selector:
    matchLabels:
      app: fantasy-frc-web
  template:
    metadata:
      labels:
        app: fantasy-frc-web
    spec:
      containers:
        - name: web
          image: {{ web_image_name }}:{{ web_image_tag }}
          imagePullPolicy: IfNotPresent
          command:
            - "./server"
          args:
            - "-skipScoring=true"
          ports:
            - containerPort: 8080
              name: http
          envFrom:
            - secretRef:
                name: fantasy-frc-app-secret
          resources:
            requests:
              memory: "128Mi"
              cpu: "100m"
            limits:
              memory: "512Mi"
              cpu: "1000m"
          startupProbe:
            httpGet:
              path: /healthz
              port: 8080
            initialDelaySeconds: 5
            periodSeconds: 5
            failureThreshold: 30
          livenessProbe:
            httpGet:
              path: /healthz
              port: 8080
            initialDelaySeconds: 0
            periodSeconds: 10
            failureThreshold: 3
          readinessProbe:
            httpGet:
              path: /healthz
              port: 8080
            initialDelaySeconds: 0
            periodSeconds: 5
            failureThreshold: 3
---
apiVersion: v1
kind: Service
metadata:
  name: fantasy-frc-web
  namespace: {{ fantasy_frc_namespace }}
spec:
  type: ClusterIP
  selector:
    app: fantasy-frc-web
  ports:
    - port: 80
      targetPort: 8080
      name: http
---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: fantasy-frc-web
  namespace: {{ fantasy_frc_namespace }}
spec:
  ingressClassName: nginx
  tls:
    - hosts:
        - {{ fantasy_frc_domain }}
      secretName: fantasy-frc-tls
  rules:
    - http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: fantasy-frc-web
                port:
                  number: 80
