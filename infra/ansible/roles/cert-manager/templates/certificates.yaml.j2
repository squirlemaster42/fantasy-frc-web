apiVersion: cert-manager.io/v1
kind: Certificate
metadata:
  name: fantasy-frc-tls
  namespace: fantasy-frc
spec:
  secretName: fantasy-frc-tls
  issuerRef:
    name: homelab-ca-issuer
    kind: ClusterIssuer
  commonName: {{ fantasy_frc_domain }}
  dnsNames:
    - {{ fantasy_frc_domain }}
---
apiVersion: cert-manager.io/v1
kind: Certificate
metadata:
  name: grafana-tls
  namespace: monitoring
spec:
  secretName: grafana-tls
  issuerRef:
    name: homelab-ca-issuer
    kind: ClusterIssuer
  commonName: {{ grafana_domain }}
  dnsNames:
    - {{ grafana_domain }}
---
apiVersion: cert-manager.io/v1
kind: Certificate
metadata:
  name: vault-tls
  namespace: vault
spec:
  secretName: vault-tls
  issuerRef:
    name: homelab-ca-issuer
    kind: ClusterIssuer
  commonName: {{ vault_domain }}
  dnsNames:
    - {{ vault_domain }}
