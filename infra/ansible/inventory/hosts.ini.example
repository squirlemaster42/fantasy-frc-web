; Copy this file to inventory/hosts.ini and update the IPs.
; Control-plane nodes also run workloads.

[control_plane]
cp1 ansible_host=192.168.1.171
cp2 ansible_host=192.168.1.172
cp3 ansible_host=192.168.1.173

[workers]
; worker1 ansible_host=192.168.1.174
; worker2 ansible_host=192.168.1.175

[k8s:children]
control_plane
workers

[all:vars]
ansible_user=deploy
ansible_ssh_private_key_file=~/.ssh/deploy
; API server virtual IP. Must be a dedicated IP for HA; for single-node tests it
; can point at the sole control-plane node's IP.
api_vip=192.168.1.170
